<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqti_v3p0" identifier="item-1" title="E2E Choice Item" adaptive="false" time-dependent="false">
  <qti-response-declaration identifier="RESPONSE" cardinality="single" base-type="identifier" />
  <qti-item-body>
    <qti-p>Pick the correct answer:</qti-p>
    <qti-choice-interaction response-identifier="RESPONSE" max-choices="1">
      <qti-simple-choice identifier="A">Apple</qti-simple-choice>
      <qti-simple-choice identifier="B">Banana</qti-simple-choice>
    </qti-choice-interaction>
    <qti-rubric-block view="scorer">
      <qti-p>[1] Selected the correct answer</qti-p>
    </qti-rubric-block>
  </qti-item-body>
</qti-assessment-item>
