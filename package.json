{
  "name": "qti-scoring-system",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint:contrast": "playwright test e2e/contrast.spec.ts",
    "verify": "npm run lint && npm run test && npm run test:e2e && npm run lint:contrast && tsc --noEmit && npm audit && npm run build",
    "prepare": "husky"
  },
  "overrides": {
    "tar": ">=7.5.8",
    "ajv": "^6.14.0",
    "minimatch": "^10.2.1",
    "postcss": ">=8.5.10",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "apply-to-qti-results": "git+https://github.com/metyatech/apply-to-qti-results.git#4765b7b5b9234ee23df84af8bcdc47820b2730e6",
    "fast-xml-parser": "^5.3.7",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "next": "16.2.7",
    "qti-html-renderer": "^0.1.0",
    "qti-reporter": "git+https://github.com/metyatech/qti-reporter.git#fd1b9267f4c1037191bbc9f13c495266d367c919",
    "qti-xml-core": "git+https://github.com/metyatech/qti-xml-core.git#b3f389a2cec7cd9429b4d5dcf5efeaff3b5a9c75",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.58.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint"
    ]
  }
}
